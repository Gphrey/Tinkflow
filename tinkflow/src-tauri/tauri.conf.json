{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Tinkflow",
  "version": "0.1.1",
  "identifier": "com.admin.tinkflow",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Tinkflow",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "license": "AGPL-3.0-or-later",
    "licenseFile": "../../LICENSE",
    "publisher": "Tinkflow",
    "copyright": "Copyright © 2025 Tinkflow",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "entitlements": "entitlements.mac.plist",
      "minimumSystemVersion": "10.15"
    }
  }
}